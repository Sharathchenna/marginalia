{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Marginalia",
  "version": "0.1.0",
  "identifier": "dev.marginalia.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Marginalia",
        "width": 1280,
        "height": 820,
        "minWidth": 920,
        "minHeight": 600,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["marginalia"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
