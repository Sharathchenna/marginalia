{
  "manifest_version": 2,
  "name": "Marginalia Connector",
  "version": "0.1.3",
  "description": "Save papers from any page into your local Marginalia library — one click, a right-click on a link, or scan a whole page for every arXiv / DOI / PDF link.",
  "browser_specific_settings": {
    "gecko": {
      "id": "marginalia-connector@marginalia.local",
      "data_collection_permissions": { "required": ["none"] }
    }
  },
  "icons": { "48": "icon.svg", "96": "icon.svg" },
  "permissions": [
    "activeTab",
    "tabs",
    "contextMenus",
    "downloads",
    "http://127.0.0.1/*"
  ],
  "background": { "scripts": ["marg.js", "background.js"] },
  "browser_action": {
    "default_title": "Save to Marginalia",
    "default_popup": "popup.html",
    "default_icon": "icon.svg"
  }
}
